# --- Data backend: Airtable ---
# Personal Access Token from https://airtable.com/create/tokens
# Scopes: data.records:read on the "Sakay Prototype" base.
# When set, `npm run sync` (and prebuild) pulls the latest car catalog
# from Airtable into lib/data/cars.generated.ts. Without it, the app
# uses whatever is currently committed in that file.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appxxnxrfm14M9ZmV
# Override these if you've renamed the tables in Airtable.
# AIRTABLE_CARS_TABLE=Cars
# AIRTABLE_HOSTS_TABLE=Hosts

# --- Auth (optional) ---
# Leave blank to run in mock-auth mode. Fill in to use Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags ---
# Black is on by default. Ride and Experiences are off.
# NEXT_PUBLIC_ENABLE_RIDE=1
# NEXT_PUBLIC_ENABLE_EXPERIENCES=1
# NEXT_PUBLIC_DISABLE_BLACK=1
